---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
    image: string
    alt: string
    height: number
}

const { image, alt, height } = Astro.props

// height? height<=100? true : false : false

// if (height) {
//     if (height <= 100) {
//         true
//     }
//     else {
//         false
//     }
// } else {
//     false
// }

// (height && height <= 100)? true : false

// if (height && height <= 100) {
//     true
// } else {
//     false
// }

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/blogs/*')
const imagePath = `../assets/blogs/${image}`

if (!images[imagePath]) {
    throw new Error(`"${imagePath}" does not exist`);
}

const finalImage = await images[imagePath]()
---

<header class="w-full py-4" style={`--header-height: ${height}dvh; height: var(--header-height);`}>
    <div class="relative w-full h-full rounded-md overflow-hidden bg-white-700/20">
        <Image 
            src={finalImage.default} 
            alt={alt || ''}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
        />
        <div class="relative z-10 h-full">
            <slot />
        </div>
    </div>
</header>
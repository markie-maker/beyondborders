---
import { Picture } from 'astro:assets'

type formats = 'png' | 'jpg' | 'jpeg' | 'tiff' | 'webp' | 'gif' | 'svg' | 'avif'

interface Props {
    imgMetadata: {
        src: string
        height: number
        width: number
        format: formats
    }
    alt: string
}

const { imgMetadata, alt } = Astro.props

---

<header class="w-full py-4 h-auto">
    <div class="relative w-full sm:aspect-21/9 aspect-video rounded-md overflow-hidden bg-white-700/20">
        <Picture 
            src={imgMetadata} 
            width={imgMetadata.width}
            height={imgMetadata.height}
            formats={['avif', 'webp']} 
            fallbackFormat="jpg"
            alt={alt || ''}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
		/>
        <div class="relative z-10 h-full">
            <slot />
        </div>
    </div>
</header>
---
import Section from "../layouts/Section.astro";
import Button from "../components/Button.astro";
import OutlinedButton from "../components/OutlinedButton.astro";
import Layout from '../layouts/Layout.astro';
import { Picture } from "astro:assets";
import backgroundImage from '../assets/background.png';
import BlogCard from "../components/BlogCard.astro";
import { getCollection } from "astro:content";

const blogs = await getCollection('blogs')
---

<Layout>
	<header class="w-full h-dvh sm:p-4">
		<div class="relative w-full h-full rounded-md overflow-hidden">

			<Picture 
				src={backgroundImage} 
				widths={[1920]} 
				formats={['avif', 'webp']} 
				fallbackFormat="jpg"
				alt="background image of a cost with rocks and a hill in the back"
				class="absolute inset-0 w-full h-full object-cover -z-10"
				loading="eager"
			/>

			<div class="flex justify-center flex-col px-8 w-full h-full my-auto text-white-100">
				<h1 class="text-5xl md:text-7xl font-bold mb-4">Insights Without Limits.</h1>
				<p class="mb-8 max-w-xl">
					Bypass the ordinary. We share travel strategies, offer distinct perspectives, and offer guides that take you beyond borders.
				</p> 
				<div class="flex gap-x-8 gap-y-4 flex-nowrap max-sm:flex-wrap">
					<Button href="#">Start Reading</Button>
					<OutlinedButton href="#">Join the Newsletter</OutlinedButton>
				</div>
			</div>
		</div>
	</header>
	

	<Section>
		<h2 class="text-5xl text-white-900 mb-2">Blogs</h2>
		<p class="text-sm mb-8">Here, we share travel tips, destination guides, and stories to empower your next adventure.</p>

		<div class="flex flex-wrap gap-4 sm:gap-6 lg:gap-8 justify-start">
			{blogs.map(blog => <BlogCard blog={blog} />)}
		</div>
	</Section>
</Layout>
